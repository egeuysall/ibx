# Deployment used by `pnpm dlx convex dev`
CONVEX_DEPLOYMENT=dev:...
NEXT_PUBLIC_CONVEX_URL=https://...
NEXT_PUBLIC_CONVEX_SITE_URL=https://...

# Vercel AI Gateway configuration
AI_GATEWAY_API_KEY=vck_...
AI_AGENT_MODEL=openai/gpt-5.4-nano

# Access key for the private app login gate
APP_ACCESS_PASSWORD=ibx_...

# Optional override for local HTTP testing. Defaults to true in production.
SESSION_COOKIE_SECURE=false

# Site URL (used for metadata, sitemap, canonical URLs, OG images)
NEXT_PUBLIC_SITE_URL=https://ibx.egeuysal.com

# Optional iCloud signed shortcut URL for install redirects.
# Must be an https://www.icloud.com/shortcuts/... URL.
SIGNED_SHORTCUT_URL=https://www.icloud.com/shortcuts/...
